/// z-tenant-flight WIT world — Duffel flight booking showcase.
///
/// Imports required host capabilities:
///   - tenant-context: tenant DID, cluster timestamp
///   - logging:        debug / info / error lines
///   - kv-store:       reads the `secrets` map for the Duffel API key
///   - http:           synchronous Duffel API calls (search + book)
///
/// Note: http requires the `Http` HostCapability to be granted at admit time.
/// The Duffel API key is stored in the z: KV map `z:<tid>:secrets` under the key
/// `duffel_api_key`. The contract builds the full map name at runtime using
/// `tenant-context.tenant-did()`. The map is created and populated by the
/// tenant SDK before the contract runs — no secret interface is needed.
package z:tenant-flight@0.3.0;

world tenant-flight {
    import host:tenant/tenant-context@1.0.0;
    import host:interfaces/logging@2.1.0;
    import host:interfaces/kv-store@2.1.0;
    import host:interfaces/http@2.1.0;

    export contracts;
}

interface contracts {
    /// Envelope sent by the T3n node for every tenant contract call.
    /// `input`   — JSON-serialized request payload specific to the function.
    /// `context` — JSON-serialized DynamicContext (node-minted, trusted).
    /// `user-profile` is intentionally absent: tenant contracts have no
    /// access to encrypted user profiles in v1 and must not receive them.
    record tenant-input {
        input:   option<list<u8>>,
        context: option<list<u8>>,
    }

    /// Search Duffel for available flights and return a list of offers.
    /// Input  (JSON): { origin, destination, departure_date, cabin_class, adult_count }
    /// Output (JSON): { offers: [{ id, total_amount, total_currency, expires_at }] }
    search-offers: func(req: tenant-input) -> result<list<u8>, string>;

    /// Book the selected offer. Returns booking ID and PNR.
    /// Input  (JSON): { offer_id, passengers: [Passenger], total_amount, total_currency }
    /// Output (JSON): { id, pnr, status }
    book-offer: func(req: tenant-input) -> result<list<u8>, string>;
}
